# Stock Analyzer Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git — it's in .gitignore

# ============ DATABASE ============
# Read-write connection (for collectors/Dagster)
DATABASE_URL=postgresql://puneetgrover@localhost/stock_analyzer

# Read-only connection (for webapp — use stock_reader user)
WEBAPP_DATABASE_URL=postgresql://stock_reader:your_password@localhost/stock_analyzer

# ============ WEBAPP AUTH ============
# Username for webapp login
WEBAPP_USERNAME=your_username

# Bcrypt hash of your password
# Generate: python3 -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
WEBAPP_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Random secret for session signing
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=your_random_64_char_hex_string

# ============ KITE CONNECT ============
# From https://developers.kite.trade
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# Zerodha login credentials (used by kite_auth/auto_login.py)
KITE_USERNAME=your_zerodha_client_id   # e.g. AB1234
KITE_PASSWORD=your_zerodha_password

# TOTP secret — the raw secret from Zerodha 2FA setup (not the 6-digit code)
# Find it: Zerodha → My Profile → Account Security → Enable TOTP → shows the secret
KITE_TOTP_SECRET=your_totp_secret_here

# ============ US MARKET DATA ============
# Polygon.io — US OHLCV (register free at polygon.io; free tier: 5 calls/min, 2yr EOD)
POLYGON_API_KEY=your_polygon_api_key_here

# ============ NOTIFICATIONS ============
# Telegram bot (Session H) — daily digest + commands + AI queries
# 1. Create a bot: Telegram → @BotFather → /newbot → copy the token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# 2. Your chat ID: message @userinfobot in Telegram, it replies with your numeric id
TELEGRAM_CHAT_ID=your_numeric_chat_id_here

# ============ AI / LLM ============
# For natural-language queries — Gemini primary, Groq fallback (both free tiers)
# Gemini key: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
# Groq key: https://console.groq.com (Llama 3.3 70B, generous free tier)
GROQ_API_KEY=your_groq_api_key_here
# Optional model overrides (defaults shown)
# GEMINI_MODEL=gemini-2.5-flash
# GROQ_MODEL=llama-3.3-70b-versatile
